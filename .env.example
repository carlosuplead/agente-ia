# App (URL usada pelo buffer para chamar /api/ai/schedule — em prod deve ser o domínio real)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres (mesmo projeto Supabase). PostgREST não expõe schemas por tenant.
# Usa a password da base (Settings → Database), NÃO a anon key.
#
# Vercel / serverless: usa Transaction pooler (porta 6543) + pgbouncer=true — evita
# "MaxClientsInSessionMode: max clients reached" com o pooler em Session (5432).
# Dashboard → Connect → Transaction pooler.
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
#
# Opcional: limite de ligações no cliente postgres (default: 1 na Vercel, 8 em local)
# POSTGRES_POOL_MAX=1
#
# Opcional: statement_timeout no Postgres (segundos). Ajuda com agregações lentas em messages
# até criares o índice messages_created_at_desc (migração 20260328160000). Ex.: 120 ou 300.
# POSTGRES_STATEMENT_TIMEOUT_SEC=120
#
# Projeto em iCloud Drive: o Turbopack/Next por vezes falha com ENOENT em .next; apaga .next e reinicia o dev server,
# ou trabalha numa cópia do repo fora do iCloud.
DATABASE_URL=

# Chamadas internas (webhook → agendamento/processamento IA). Gerar string longa aleatória.
# Também usado em GET/POST /api/ai/followup-cron (Bearer) para follow-ups automáticos
# e GET/POST /api/cron/whatsapp-broadcast-queue (Bearer) para a fila de disparos Meta.
INTERNAL_AI_SECRET=

# Uazapi — apikey enviada em pedidos à API (instância + mensagens)
UAZAPI_URL=https://api.uazapi.com
UAZAPI_GLOBAL_TOKEN=
# Opcional: token administrativo para criar instâncias (se diferente do global)
UAZAPI_ADMIN_TOKEN=

# Meta WhatsApp Cloud API (provider official)
META_APP_ID=
META_APP_SECRET=
# Opcional (default: NEXT_PUBLIC_SITE_URL + /api/auth/meta/whatsapp/callback)
# META_OAUTH_REDIRECT_URI=
# Opcional (fallback: META_APP_SECRET)
# META_OAUTH_STATE_SECRET=
# Token de verificação do webhook oficial
META_WEBHOOK_VERIFY_TOKEN=

# LLM (fallback global; por workspace podes guardar chaves no dashboard → ai_agent_config)
GOOGLE_API_KEY=
OPENAI_API_KEY=

# Google Calendar (OAuth2 — agente: sugerir horários e criar eventos; dashboard → Agente IA → Google Agenda)
# Cria credenciais "OAuth client" na Google Cloud Console, redirect URI = NEXT_PUBLIC_SITE_URL + /api/auth/google/calendar/callback
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
# Opcional (default: NEXT_PUBLIC_SITE_URL + /api/auth/google/calendar/callback)
# GOOGLE_CALENDAR_OAUTH_REDIRECT_URI=
# Opcional (default: INTERNAL_AI_SECRET)
# GOOGLE_CALENDAR_OAUTH_STATE_SECRET=

# ElevenLabs (tool send_voice_message no agente; requer ativar no workspace)
ELEVENLABS_API_KEY=
# Opcional: voz por defeito se o workspace não tiver elevenlabs_voice_id
ELEVENLABS_DEFAULT_VOICE_ID=
# Opcional: modelo TTS (default no código: eleven_multilingual_v2)
# ELEVENLABS_MODEL_ID=
