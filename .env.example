# App (URL usada pelo buffer para chamar /api/ai/schedule — em prod deve ser o domínio real)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Opcional: desativar POST /api/auth/signup (só convites / admin). Valores: 1, true, yes.
# SIGNUP_DISABLED=1

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres (mesmo projeto Supabase). PostgREST não expõe schemas por tenant.
# Usa a password da base (Settings → Database), NÃO a anon key.
#
# Vercel / serverless: usa Transaction pooler (porta 6543) + pgbouncer=true — evita
# "MaxClientsInSessionMode: max clients reached" com o pooler em Session (5432).
# Dashboard → Connect → Transaction pooler.
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
#
# Opcional: limite de ligações no cliente postgres (default: 1 na Vercel, 8 em local)
# POSTGRES_POOL_MAX=1
#
# Opcional: statement_timeout no Postgres (segundos). Ajuda com agregações lentas em messages
# até criares o índice messages_created_at_desc (migração 20260328160000). Ex.: 120 ou 300.
# POSTGRES_STATEMENT_TIMEOUT_SEC=120
#
# Projeto em iCloud Drive: o Turbopack/Next por vezes falha com ENOENT em .next; apaga .next e reinicia o dev server,
# ou trabalha numa cópia do repo fora do iCloud.
DATABASE_URL=

# Chamadas internas (webhook → agendamento/processamento IA). Gerar string longa aleatória.
# Usado em POST /api/ai/schedule, POST /api/ai/process e GET/POST /api/ai/followup-cron (Authorization: Bearer …).
INTERNAL_AI_SECRET=
# Opcional: segundo Bearer aceite nas mesmas rotas (ex. crons com segredo dedicado). Nunca confies só no header x-vercel-cron.
# CRON_SECRET=
# Opcional: Bearer dedicado para GET/POST /api/cron/whatsapp-broadcast-queue (fila disparos Meta).
# Se vazio, o cron de broadcasts usa INTERNAL_AI_SECRET.
# INTERNAL_BROADCAST_SECRET=

# ── Disparos via n8n (opt-in) ──
# Quando N8N_DISPATCH_ENABLED=true, o cron de disparos deixa de chamar a Meta Cloud
# directamente e empurra cada batch para o webhook n8n definido em N8N_WEBHOOK_URL.
# O n8n é o responsável por enviar (pode usar as credenciais Meta passadas no payload
# ou, futuramente, UAZAPI) e devolver status via POST ao callback, assinado em HMAC.
# N8N_DISPATCH_ENABLED=true
# N8N_WEBHOOK_URL=https://n8nsecundario.adventurecriative.com.br/webhook/agente-ia-disparos
# N8N_WEBHOOK_SECRET=troca-por-uma-string-aleatoria-longa   # partilhado com n8n (HMAC SHA-256)
# N8N_CALLBACK_BASE_URL=https://agente-ia-chi.vercel.app     # URL pública do SaaS (fallback: NEXT_PUBLIC_APP_URL / NEXT_PUBLIC_SITE_URL)

# Uazapi — URL base = «Server URL» do painel, sem barra no fim (o mesmo host onde corres /instance/init).
# Ex.: https://api.uazapi.com | https://free.uazapi.com | servidor white-label → https://metricsia.uazapi.com
# Se UAZAPI_URL não for o do painel, /instance/connect devolve 401 (Invalid/Missing token).
UAZAPI_URL=https://api.uazapi.com
# Admintoken do painel para POST /instance/init (criar instância). Usa UAZAPI_ADMIN_TOKEN ou, se vazio, este.
# Não é o token da instância — e não deve ser enviado em /instance/connect nem /instance/status (causa 401).
UAZAPI_GLOBAL_TOKEN=
# Opcional: admintoken só para criar instâncias (recomendado separar de GLOBAL se usares GLOBAL para outra coisa)
UAZAPI_ADMIN_TOKEN=
# Opcional: URL do teu relay (ex. n8n) para o webhook Uazapi — evita expor o URL com ?token=... diretamente ao Vercel.
# WHATSAPP_WEBHOOK_RELAY_URL=https://...

# Meta WhatsApp Cloud API (provider official)
META_APP_ID=
META_APP_SECRET=
# Opcional (default: NEXT_PUBLIC_SITE_URL + /api/auth/meta/whatsapp/callback)
# META_OAUTH_REDIRECT_URI=
# Opcional (fallback: META_APP_SECRET)
# META_OAUTH_STATE_SECRET=
# Token de verificação do webhook oficial
META_WEBHOOK_VERIFY_TOKEN=

# LLM (fallback global; por workspace podes guardar chaves no dashboard → ai_agent_config)
GOOGLE_API_KEY=
OPENAI_API_KEY=
# Opcional: com este segredo definido, chaves guardadas no painel são encriptadas na BD (prefixo ac:v1:).
# WORKSPACE_LLM_KEYS_SECRET=

# Google Calendar (OAuth2 — agente: sugerir horários e criar eventos; dashboard → Agente IA → Google Agenda)
# Cria credenciais "OAuth client" na Google Cloud Console, redirect URI = NEXT_PUBLIC_SITE_URL + /api/auth/google/calendar/callback
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
# Opcional (default: NEXT_PUBLIC_SITE_URL + /api/auth/google/calendar/callback)
# GOOGLE_CALENDAR_OAUTH_REDIRECT_URI=
# Opcional (default: INTERNAL_AI_SECRET)
# GOOGLE_CALENDAR_OAUTH_STATE_SECRET=

# ElevenLabs (tool send_voice_message no agente; requer ativar no workspace)
ELEVENLABS_API_KEY=
# Opcional: voz por defeito se o workspace não tiver elevenlabs_voice_id
ELEVENLABS_DEFAULT_VOICE_ID=
# Opcional: modelo TTS (default no código: eleven_multilingual_v2)
# ELEVENLABS_MODEL_ID=
